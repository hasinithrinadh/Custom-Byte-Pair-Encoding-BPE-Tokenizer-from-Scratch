      "id": "92f8389b-6af7-4778-9ee4-d89ae633f641",
      "cell_type": "code",
      "source": "import numpy as np\nwords = np.array([\"low\", \"lower\", \"lowest\", \"newest\"])\nvocab = []\nfor word in words:\n    chars = list(word)\n    chars.append(\"</w>\")\n    vocab.append(chars)\n\nprint(\"Initial Vocabulary\")\nfor word in vocab:\n    print(word)\npair_freq = {}\nfor word in vocab:\n    for i in range(len(word) - 1):\n        pair = (word[i], word[i + 1])\n\n        if pair in pair_freq:\n            pair_freq[pair] += 1\n        else:\n            pair_freq[pair] = 1\nprint(\"\\nPair Frequencies\")\nfor pair, count in pair_freq.items():\n    print(pair, \":\", count)\nbest_pair = max(pair_freq, key=pair_freq.get)\nprint(\"\\nMost Frequent Pair:\", best_pair)\nnew_vocab = []\nfor word in vocab:\n    merged = []\n    i = 0\n    while i < len(word):\n        if (\n            i < len(word) - 1\n            and word[i] == best_pair[0]\n            and word[i + 1] == best_pair[1]\n        ):\n            merged.append(word[i] + word[i + 1])\n            i += 2\n        else:\n            merged.append(word[i])\n            i += 1\n\n    new_vocab.append(merged)\n\nprint(\"\\nVocabulary After Merge\")\nfor word in new_vocab:\n    print(word)",
